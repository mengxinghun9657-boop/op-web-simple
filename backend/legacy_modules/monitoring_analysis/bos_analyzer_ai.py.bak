#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
BOS存储分析器（AI驱动版本）
完全重构，解决大数据量时的可读性问题
采用"倒金字塔"信息架构
"""

import pandas as pd
from datetime import datetime, timedelta, timezone
from typing import List, Dict, Any, Optional
import json


class BOSAnalyzerAI:
    """BOS对象存储分析器（AI增强版）"""
    
    def __init__(self, bcm_client=None, user_id: str = "f008db4751894afe9b851e32a2068335"):
        """
        初始化BOS分析器
        
        Args:
            bcm_client: BCM客户端实例
            user_id: 百度云用户ID
        """
        self.client = bcm_client
        self.user_id = user_id
        self.scope = "BCE_BOS"
        self.region = "cd"
        self.metric_names = ["BucketObjectCount", "BucketSpaceUsedBytes"]
        self.statistics = ["maximum"]
        self.buckets = []
        
        # 初始化ERNIE客户端用于AI解读
        self.ernie_client = None
        try:
            from app.services.ai.ernie_client import get_ernie_client
            self.ernie_client = get_ernie_client()
            print("✅ ERNIE客户端初始化成功")
        except Exception as e:
            print(f"⚠️ ERNIE客户端初始化失败: {e}，将使用本地算法")
    
    def load_buckets_from_file(self, file_path: str) -> List[str]:
        """从文件加载Bucket列表"""
        try:
            with open(file_path, 'r') as f:
                buckets = [line.strip() for line in f if line.strip()]
            print(f"从{file_path}加载了{len(buckets)}个Bucket")
            self.buckets = buckets
            return buckets
        except FileNotFoundError:
            print(f"文件{file_path}未找到")
            return []
    
    def load_buckets_from_list(self, buckets: List[str]):
        """从列表加载Bucket"""
        self.buckets = buckets
        print(f"加载了{len(buckets)}个Bucket")
    
    def get_bucket_metrics(self) -> List[Dict[str, Any]]:
        """获取所有Bucket的监控指标"""
        if not self.client:
            raise Exception("BCM客户端未初始化")
        
        # UTC时间近一天的数据（结束时间不能晚于2小时前）
        now = datetime.now(timezone.utc)
        end_time = (now - timedelta(hours=3)).strftime('%Y-%m-%dT%H:%M:%SZ')
        start_time = (now - timedelta(hours=27)).strftime('%Y-%m-%dT%H:%M:%SZ')
        
        print(f"查询时间范围: {start_time} 至 {end_time} (UTC)")
        
        results = []
        total_buckets = len(self.buckets)
        
        for idx, bucket in enumerate(self.buckets, 1):
            dimensions = [[{"name": "BucketId", "value": bucket}]]
            
            try:
                response = self.client.get_all_data_metrics_v2(
                    self.user_id, self.scope, self.region, dimensions, 
                    self.metric_names, self.statistics, start_time, end_time, 
                    type="Instance", cycle=3600
                )
                
                space_used = 0
                object_count = 0
                
                if hasattr(response, 'metrics'):
                    for metric in response.metrics:
                        if metric.metric_name == 'BucketSpaceUsedBytes' and metric.data_points:
                            space_used = max([p.maximum for p in metric.data_points if p.maximum is not None], default=0)
                        elif metric.metric_name == 'BucketObjectCount' and metric.data_points:
                            object_count = max([p.maximum for p in metric.data_points if p.maximum is not None], default=0)
                
                print(f"[{idx}/{total_buckets}] {bucket}: {space_used / (1024**5):.6f} PB, {object_count:,} 文件")
                
                results.append({
                    'bucket': bucket,
                    'space': space_used,
                    'objects': object_count
                })
                
            except Exception as e:
                print(f"处理Bucket {bucket} 时出错: {e}")
                results.append({
                    'bucket': bucket,
                    'space': 0,
                    'objects': 0
                })
        
        return results
    
    def get_summary_stats(self, results: List[Dict]) -> Dict[str, Any]:
        """获取汇总统计"""
        total_space = sum(r['space'] for r in results)
        total_objects = sum(r['objects'] for r in results)
        
        return {
            'total_buckets': len(results),
            'total_space_bytes': total_space,
            'total_space_pb': total_space / (1024**5),
            'total_objects': total_objects
        }
    
    def detect_anomalies(self, results: List[Dict]) -> List[Dict]:
        """检测异常Bucket（存储增长异常）"""
        anomalies = []
        
        # 计算平均存储空间
        spaces = [r['space'] for r in results if r['space'] > 0]
        if not spaces:
            return anomalies
        
        avg_space = sum(spaces) / len(spaces)
        std_space = (sum((x - avg_space) ** 2 for x in spaces) / len(spaces)) ** 0.5
        
        # 3-sigma异常检测
        threshold = avg_space + 3 * std_space
        
        for result in results:
            if result['space'] > threshold:
                anomalies.append({
                    'bucket': result['bucket'],
                    'space_pb': result['space'] / (1024**5),
                    'objects': result['objects'],
                    'deviation': (result['space'] - avg_space) / std_space if std_space > 0 else 0,
                    'severity': 'critical' if result['space'] > avg_space + 4 * std_space else 'warning'
                })
        
        # 按偏离程度排序
        anomalies.sort(key=lambda x: -x['deviation'])
        return anomalies
    
    def identify_low_usage(self, results: List[Dict], threshold_pb: float = 0.001) -> List[Dict]:
        """识别低使用率Bucket（成本优化机会）"""
        low_usage = []
        
        for result in results:
            space_pb = result['space'] / (1024**5)
            if 0 < space_pb < threshold_pb:
                low_usage.append({
                    'bucket': result['bucket'],
                    'space_pb': space_pb,
                    'objects': result['objects']
                })
        
        # 按存储空间排序
        low_usage.sort(key=lambda x: x['space_pb'])
        return low_usage
    
    def get_top_buckets(self, results: List[Dict], top_n: int = 30) -> List[Dict]:
        """获取存储空间TOP N的Bucket"""
        sorted_results = sorted(results, key=lambda x: x['space'], reverse=True)
        top_buckets = sorted_results[:top_n]
        
        # 添加排名和PB单位
        for idx, item in enumerate(top_buckets, 1):
            item['rank'] = idx
            item['space_pb'] = item['space'] / (1024**5)
        
        return top_buckets
    
    def generate_recommendations(self, results: List[Dict], anomalies: List[Dict], low_usage: List[Dict]) -> List[Dict]:
        """生成优化建议"""
        recommendations = []
        
        # 异常存储增长建议
        if anomalies:
            recommendations.append({
                'type': 'anomaly_alert',
                'priority': 'high',
                'title': '存储异常增长警告',
                'description': f'检测到 {len(anomalies)} 个Bucket存储空间异常增长',
                'affected_buckets': [a['bucket'] for a in anomalies[:5]],
                'action': '建议检查这些Bucket的数据增长原因，确认是否为正常业务需求'
            })
        
        # 低使用率Bucket建议
        if low_usage:
            total_low_space = sum(b['space_pb'] for b in low_usage)
            recommendations.append({
                'type': 'cost_optimization',
                'priority': 'medium',
                'title': '低使用率Bucket优化',
                'description': f'发现 {len(low_usage)} 个低使用率Bucket，总计 {total_low_space:.3f} PB',
                'affected_buckets': [b['bucket'] for b in low_usage[:10]],
                'action': '建议评估这些Bucket的必要性，考虑清理或归档'
            })
        
        # 容量规划建议
        summary = self.get_summary_stats(results)
        recommendations.append({
            'type': 'capacity_planning',
            'priority': 'low',
            'title': '容量规划建议',
            'description': f'当前总存储: {summary["total_space_pb"]:.2f} PB',
            'action': '建议定期监控存储增长趋势，提前规划容量'
        })
        
        return recommendations
    
    async def generate_ai_summary(self, results: List[Dict], anomalies: List[Dict], recommendations: List[Dict]) -> str:
        """生成AI执行摘要（优先使用远程API）"""
        
        # 优先使用远程ERNIE API
        if self.ernie_client:
            try:
                ai_summary = await self._generate_ai_summary_remote(results, anomalies, recommendations)
                if ai_summary:
                    print("✅ 使用远程API生成AI摘要成功")
                    return ai_summary
            except Exception as e:
                print(f"⚠️ 远程API生成失败，使用本地算法: {e}")
        
        # 降级方案：本地算法
        summary = self.get_summary_stats(results)
        top10 = self.get_top_buckets(results, 10)
        
        # 计算TOP10占比
        top10_space = sum(b['space'] for b in top10)
        top10_percentage = (top10_space / summary['total_space_bytes'] * 100) if summary['total_space_bytes'] > 0 else 0
        
        summary_text = f"""
<h3>📊 核心发现</h3>
<p>本次分析覆盖 <strong>{summary['total_buckets']}</strong> 个Bucket，总存储空间 <strong>{summary['total_space_pb']:.2f} PB</strong>，
包含 <strong>{summary['total_objects']:,}</strong> 个对象。</p>

<h3>🔍 关键洞察</h3>
<ul>
    <li><strong>存储集中度</strong>: TOP 10 Bucket占总存储的 {top10_percentage:.1f}%，存储资源高度集中</li>
    <li><strong>异常检测</strong>: 发现 {len(anomalies)} 个存储异常增长的Bucket，需要重点关注</li>
    <li><strong>优化建议</strong>: 共识别 {len(recommendations)} 项优化建议，可显著降低存储成本</li>
</ul>
"""
        return summary_text
    
    async def _generate_ai_summary_remote(self, results: List[Dict], anomalies: List[Dict], recommendations: List[Dict]) -> Optional[str]:
        """使用远程ERNIE API生成AI摘要"""
        summary = self.get_summary_stats(results)
        top10 = self.get_top_buckets(results, 10)
        
        # 构建提示词
        prompt = f"""
请对以下BOS对象存储监控数据进行专业的AI分析和总结：

【存储概览】
- Bucket总数: {summary['total_buckets']}个
- 总存储空间: {summary['total_space_pb']:.2f} PB
- 总对象数: {summary['total_objects']:,}个
- 异常Bucket数: {len(anomalies)}个
- 优化建议数: {len(recommendations)}项

【TOP 5 Bucket】
{self._format_top_buckets(top10[:5])}

请生成一段HTML格式的执行摘要（200字以内），包括：
1. 核心发现（存储规模、集中度）
2. 关键洞察（异常情况、优化空间）
3. 主要建议

要求：使用HTML标签（h3, p, ul, li, strong），语言简洁专业。
"""
        
        # 调用ERNIE API
        response = await self.ernie_client.chat(
            messages=[{"role": "user", "content": prompt}],
            temperature=0.7,
            max_tokens=400
        )
        
        return response
    
    def _format_top_buckets(self, buckets: List[Dict]) -> str:
        """格式化TOP Bucket信息"""
        if not buckets:
            return "无数据"
        
        lines = []
        for i, bucket in enumerate(buckets, 1):
            space_gb = bucket['space'] / (1024**3)
            lines.append(f"{i}. {bucket['name']}: {space_gb:.2f} GB, {bucket['objects']:,}个对象")
        
        return "\n".join(lines)
    <li><strong>优化机会</strong>: 识别出 {len([r for r in recommendations if r['type'] == 'cost_optimization'])} 项成本优化建议</li>
</ul>
"""
        
        # 添加优先行动项
        if recommendations:
            summary_text += "\n<h3>💡 优先行动项</h3>\n<ol>\n"
            for rec in recommendations[:3]:
                summary_text += f"    <li><strong>{rec['title']}</strong>: {rec['description']}</li>\n"
            summary_text += "</ol>"
        
        return summary_text
    
    def generate_html_report(self, results: List[Dict]) -> str:
        """生成AI驱动的倒金字塔HTML报告"""
        summary = self.get_summary_stats(results)
        anomalies = self.detect_anomalies(results)
        low_usage = self.identify_low_usage(results)
        top30 = self.get_top_buckets(results, 30)
        recommendations = self.generate_recommendations(results, anomalies, low_usage)
        ai_summary = self.generate_ai_summary(results, anomalies, recommendations)
        
        current_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        
        # 准备图表数据
        top30_labels = [item['bucket'] for item in top30]
        top30_data = [item['space_pb'] for item in top30]
        
        # 构建异常Bucket表格
        anomaly_rows = ''
        for anomaly in anomalies:
            severity_color = '#F44336' if anomaly['severity'] == 'critical' else '#FF9800'
            anomaly_rows += f"""
            <tr>
                <td>{anomaly['bucket']}</td>
                <td>{anomaly['space_pb']:.6f}</td>
                <td>{anomaly['objects']:,}</td>
                <td style="color: {severity_color};">{anomaly['deviation']:.2f}σ</td>
            </tr>"""
        
        # 构建低使用率Bucket表格
        low_usage_rows = ''
        for bucket in low_usage[:20]:
            low_usage_rows += f"""
            <tr>
                <td>{bucket['bucket']}</td>
                <td>{bucket['space_pb']:.6f}</td>
                <td>{bucket['objects']:,}</td>
            </tr>"""
        
        # 构建TOP30表格
        top30_rows = ''
        for item in top30:
            top30_rows += f"""
            <tr>
                <td>{item['rank']}</td>
                <td>{item['bucket']}</td>
                <td>{item['space_pb']:.6f}</td>
                <td>{item['objects']:,}</td>
            </tr>"""
        
        # 构建优化建议卡片
        recommendation_cards = ''
        priority_colors = {'high': '#F44336', 'medium': '#FF9800', 'low': '#4CAF50'}
        for rec in recommendations:
            color = priority_colors.get(rec['priority'], '#2196F3')
            recommendation_cards += f"""
            <div class="recommendation-card" style="border-left: 4px solid {color};">
                <h4>{rec['title']}</h4>
                <p>{rec['description']}</p>
                <p class="action"><strong>建议行动</strong>: {rec['action']}</p>
            </div>"""
        
        html_content = f"""<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BOS存储分析报告（AI驱动）</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {{ margin: 0; padding: 0; box-sizing: border-box; }}
        body {{ 
            font-family: 'Microsoft YaHei', Arial, sans-serif; 
            background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
            color: #333; line-height: 1.6; min-height: 100vh; padding: 20px;
        }}
        .container {{ 
            max-width: 1400px; margin: 0 auto; 
            background: rgba(255, 255, 255, 0.95);
            border-radius: 20px; padding: 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }}
        h1 {{ 
            text-align: center; 
            background: linear-gradient(45deg, #1976D2, #42A5F5);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text; margin-bottom: 40px; font-size: 2.5em; font-weight: 300;
        }}
        .section {{ 
            margin-bottom: 40px; background: white;
            border-radius: 15px; padding: 30px; 
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
            border: 1px solid rgba(25, 118, 210, 0.1);
        }}
        .section h2 {{ 
            color: #1976D2; margin-bottom: 20px; padding-bottom: 15px; 
            border-bottom: 2px solid #E3F2FD; font-weight: 500; font-size: 1.8em;
        }}
        .section h3 {{
            color: #1976D2; margin-top: 20px; margin-bottom: 15px;
            font-weight: 500; font-size: 1.3em;
        }}
        .ai-summary {{
            background: linear-gradient(135deg, #F3E5F5 0%, #E3F2FD 100%);
            border-left: 6px solid #1976D2;
        }}
        .stats-grid {{ 
            display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); 
            gap: 20px; margin: 30px 0;
        }}
        .stat-card {{ 
            background: white; padding: 25px; border-radius: 15px; 
            text-align: center; box-shadow: 0 8px 25px rgba(0,0,0,0.08);
            transition: all 0.3s ease; border-left: 4px solid #1976D2;
        }}
        .stat-card:hover {{ transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.15); }}
        .stat-number {{ color: #1976D2; font-size: 2.5em; font-weight: 300; margin-bottom: 10px; }}
        .stat-label {{ color: #666; font-size: 0.9em; font-weight: 500; }}
        .recommendation-card {{
            background: white; padding: 20px; border-radius: 10px;
            margin-bottom: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }}
        .recommendation-card h4 {{ color: #1976D2; margin-bottom: 10px; }}
        .recommendation-card p {{ color: #555; margin-bottom: 8px; }}
        .recommendation-card .action {{ color: #666; font-style: italic; }}
        table {{ 
            width: 100%; border-collapse: collapse; background: white; 
            border-radius: 10px; overflow: hidden; margin: 20px 0;
        }}
        th, td {{ padding: 15px; text-align: center; border-bottom: 1px solid #E3F2FD; }}
        th {{ 
            background: linear-gradient(45deg, #1976D2, #42A5F5); 
            color: white; font-weight: 500; position: sticky; top: 0;
        }}
        tr:nth-child(even) {{ background-color: #F8FAFC; }}
        tr:hover {{ background-color: #E3F2FD; }}
        .chart-container {{ margin: 30px 0; text-align: center; }}
        .chart-wrapper {{ 
            display: inline-block; width: 100%; max-width: 1200px; height: 500px; 
            margin: 20px auto; background: white; border-radius: 15px; padding: 20px; 
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        }}
        .toggle-btn {{
            background: linear-gradient(45deg, #1976D2, #42A5F5);
            color: white; border: none; padding: 12px 24px;
            border-radius: 25px; cursor: pointer; font-size: 16px;
            margin-bottom: 20px; transition: all 0.3s ease;
        }}
        .toggle-btn:hover {{ transform: scale(1.05); box-shadow: 0 5px 15px rgba(25, 118, 210, 0.3); }}
        .collapsible {{ display: none; }}
        .collapsible.show {{ display: block; }}
        .footer {{ 
            margin-top: 50px; padding: 30px; 
            background: linear-gradient(45deg, #F3E5F5, #E3F2FD); 
            border-radius: 15px; text-align: center; color: #666;
        }}
    </style>
</head>
<body>
    <div class="container">
        <h1>🗄️ BOS存储分析报告（AI驱动）</h1>
        
        <!-- AI执行摘要 -->
        <div class="section ai-summary">
            <h2>🤖 AI执行摘要</h2>
            {ai_summary}
        </div>
        
        <!-- 核心指标 -->
        <div class="section">
            <h2>📊 核心指标</h2>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-number">{summary['total_buckets']}</div>
                    <div class="stat-label">Bucket总数</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">{summary['total_space_pb']:.2f} PB</div>
                    <div class="stat-label">总存储空间</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">{summary['total_objects']:,}</div>
                    <div class="stat-label">总对象数</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">{len(anomalies)}</div>
                    <div class="stat-label">异常Bucket数</div>
                </div>
            </div>
        </div>
        
        <!-- 异常检测 -->
        <div class="section">
            <h2>⚠️ 异常检测</h2>
            <p>基于3-sigma统计方法检测存储空间异常增长的Bucket</p>
            {f'<table><thead><tr><th>Bucket名称</th><th>存储空间(PB)</th><th>对象数</th><th>偏离程度</th></tr></thead><tbody>{anomaly_rows}</tbody></table>' if anomalies else '<p style="color: #4CAF50; text-align: center; padding: 20px;">✓ 未检测到异常Bucket</p>'}
        </div>
        
        <!-- 优化建议 -->
        <div class="section">
            <h2>💡 优化建议</h2>
            {recommendation_cards}
        </div>
        
        <!-- TOP30存储空间 -->
        <div class="section">
            <h2>🏆 TOP30存储空间</h2>
            <div class="chart-container">
                <div class="chart-wrapper">
                    <canvas id="top30Chart"></canvas>
                </div>
            </div>
            <button class="toggle-btn" onclick="toggleSection('top30Table')">展开/收起详细数据</button>
            <div id="top30Table" class="collapsible">
                <table>
                    <thead>
                        <tr><th>排名</th><th>Bucket名称</th><th>存储空间(PB)</th><th>对象数</th></tr>
                    </thead>
                    <tbody>{top30_rows}</tbody>
                </table>
            </div>
        </div>
        
        <!-- 低使用率Bucket -->
        {f'''<div class="section">
            <h2>💰 成本优化机会</h2>
            <p>以下Bucket存储空间较小（< 0.001 PB），建议评估其必要性</p>
            <button class="toggle-btn" onclick="toggleSection('lowUsageTable')">展开/收起低使用率Bucket</button>
            <div id="lowUsageTable" class="collapsible">
                <table>
                    <thead>
                        <tr><th>Bucket名称</th><th>存储空间(PB)</th><th>对象数</th></tr>
                    </thead>
                    <tbody>{low_usage_rows}</tbody>
                </table>
            </div>
        </div>''' if low_usage else ''}
        
        <div class="footer">
            <p>📅 报告生成时间: {current_time}</p>
            <p>🔧 分析工具: BOS存储分析系统（AI驱动版）</p>
        </div>
    </div>
    
    <script>
        // TOP30图表
        const ctx = document.getElementById('top30Chart').getContext('2d');
        new Chart(ctx, {{
            type: 'bar',
            data: {{
                labels: {json.dumps(top30_labels)},
                datasets: [{{
                    label: '存储空间(PB)',
                    data: {json.dumps(top30_data)},
                    backgroundColor: 'rgba(25, 118, 210, 0.6)',
                    borderColor: 'rgba(25, 118, 210, 1)',
                    borderWidth: 1
                }}]
            }},
            options: {{
                responsive: true,
                maintainAspectRatio: false,
                plugins: {{
                    title: {{
                        display: true,
                        text: 'TOP30 Bucket存储空间分布',
                        font: {{ size: 18 }}
                    }},
                    legend: {{ display: false }}
                }},
                scales: {{
                    y: {{
                        beginAtZero: true,
                        title: {{
                            display: true,
                            text: '存储空间(PB)'
                        }}
                    }},
                    x: {{
                        title: {{
                            display: true,
                            text: 'Bucket名称'
                        }},
                        ticks: {{
                            maxRotation: 45,
                            minRotation: 45
                        }}
                    }}
                }}
            }}
        }});
        
        // 切换显示/隐藏
        function toggleSection(id) {{
            const element = document.getElementById(id);
            element.classList.toggle('show');
        }}
    </script>
</body>
</html>"""
        
        return html_content
    
    def analyze(self, buckets: Optional[List[str]] = None) -> Dict[str, Any]:
        """执行完整的BOS存储分析"""
        if buckets:
            self.load_buckets_from_list(buckets)
        
        if not self.buckets:
            raise Exception("未加载任何Bucket")
        
        # 获取Bucket指标
        print("开始获取Bucket存储指标...")
        results = self.get_bucket_metrics()
        
        if not results:
            return {
                'success': False,
                'message': '未获取到任何Bucket数据',
                'bucket_count': len(self.buckets)
            }
        
        # 生成统计数据
        summary = self.get_summary_stats(results)
        anomalies = self.detect_anomalies(results)
        low_usage = self.identify_low_usage(results)
        top30 = self.get_top_buckets(results, 30)
        recommendations = self.generate_recommendations(results, anomalies, low_usage)
        
        return {
            'success': True,
            'bucket_count': len(self.buckets),
            'summary': summary,
            'anomalies': anomalies,
            'low_usage': low_usage,
            'top30': top30,
            'recommendations': recommendations,
            'all_buckets': results,
            'analysis_time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        }
